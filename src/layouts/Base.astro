---
import '@/styles/global.css';
import { site } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = site.title,
  description = site.description,
  canonical = site.url,
} = Astro.props;

const ogImage = new URL(site.ogImage, site.url).toString();
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0A0A0F" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: Inter + JetBrains Mono. Preconnect for the swap. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- JSON-LD person schema. Helps Google show the right knowledge panel
         when "martin janus quizzolingo" is searched. -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Martin Janus',
        url: site.url,
        email: `mailto:${site.email}`,
        sameAs: [site.linkedin, site.quizzolingo],
        jobTitle: 'Manufacturing-Technology Specialist',
        worksFor: { '@type': 'Organization', name: 'Quizzolingo' },
        nationality: 'Slovak',
        knowsAbout: [
          'Manufacturing technology',
          'CATIA V5',
          '3DExperience',
          'Bodyshop process engineering',
          'C#',
          'VBA',
          'Industrial SaaS',
        ],
      })}
    />

    <!-- Cloudflare Web Analytics (privacy-friendly, no GDPR banner needed).
         Token gets injected automatically once the Pages project is bound
         to a Web Analytics site — no manual edit needed. -->
  </head>
  <body class="bg-bg text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-3 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
