---
import type { Project } from '@/data/projects';

interface Props { project: Project; }
const { project } = Astro.props;
---
<article
  class="card-accent hover-lift relative flex h-full flex-col rounded-xl border border-line bg-surface p-6 pl-7 sm:p-8 sm:pl-9"
>
  <p class="label">{project.context}</p>

  <h3 class="mt-3 text-xl font-semibold tracking-tightish text-ink sm:text-2xl">
    {project.title}
  </h3>

  <p class="mt-3 text-sm leading-relaxed text-muted sm:text-base">
    {project.description}
  </p>

  <ul class="mt-5 flex flex-wrap gap-1.5">
    {project.tech.map((t) => (
      <li class="rounded-md border border-line bg-bg/60 px-2 py-1 font-mono text-[11px] text-muted">
        {t}
      </li>
    ))}
  </ul>

  {project.link && (
    <a
      href={project.link.href}
      target="_blank"
      rel="noopener"
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:underline"
    >
      {project.link.label}
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7 17 17 7"/>
        <path d="M7 7h10v10"/>
      </svg>
    </a>
  )}
</article>
