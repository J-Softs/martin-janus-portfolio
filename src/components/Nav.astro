---
import { nav, site } from '@/data/site';
---
<nav class="sticky top-0 z-40 border-b border-line bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/65">
  <div class="mx-auto flex h-16 max-w-grid-wide items-center justify-between px-5 sm:px-8">
    <a href="#top" class="group inline-flex items-center gap-2.5" aria-label="Martin Janus — back to top">
      <span
        class="grid h-8 w-8 place-items-center rounded-md border border-line bg-surface font-mono text-sm font-medium text-ink transition-colors group-hover:border-accent group-hover:text-accent"
        aria-hidden="true"
      >MJ</span>
      <span class="hidden font-medium tracking-tightish sm:inline">Martin Janus</span>
    </a>

    <div class="flex items-center gap-2 sm:gap-6">
      <ul class="hidden items-center gap-6 text-sm text-muted sm:flex">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="transition-colors hover:text-ink"
            >{item.label}</a>
          </li>
        ))}
      </ul>
      <a
        href={site.cvPath}
        download
        class="inline-flex h-9 items-center gap-2 rounded-md border border-line bg-surface px-3 text-sm text-ink transition-colors hover:border-accent hover:text-accent"
      >
        <span>Download CV</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
