    <p class="font-mono text-xs text-muted">
      © {year} Martin Janus. &nbsp;Built with Astro + Tailwind on Cloudflare Pages.
    </p>
    <a href="#top" class="font-mono text-xs text-muted underline-offset-4 hover:text-accent hover:underline">
      ↑ back to top
    </a>
  </div>
</footer>
