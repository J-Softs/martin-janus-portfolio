---
import { site } from '@/data/site';
---
<section id="contact" class="border-b border-line">
  <div class="mx-auto max-w-grid-wide px-5 py-24 sm:px-8 sm:py-32">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-16">
      <header class="max-w-prose-wide">
        <p class="label mb-4">Contact</p>
        <h2 class="h-display text-3xl text-ink sm:text-4xl lg:text-5xl">
          Let&rsquo;s work together.
        </h2>
        <p class="mt-4 text-base text-muted sm:text-lg">
          Quickest path is email — typically reply within a business day.
        </p>

        <div class="mt-8 space-y-3">
          <a
            href={`mailto:${site.email}`}
            class="hover-lift inline-flex h-11 items-center gap-2 rounded-md border border-accent bg-accent px-5 text-sm font-medium text-white hover:bg-accent/90"
          >
            Email me
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>

        <ul class="mt-10 space-y-2.5 font-mono text-sm text-muted">
          <li>
            <span class="text-accent">$</span>
            email
            <a
              href={`mailto:${site.email}`}
              class="ml-2 text-ink underline-offset-4 hover:text-accent hover:underline"
            >{site.email}</a>
          </li>
          <li>
            <span class="text-accent">$</span>
            linkedin
            <a
              href={site.linkedin}
              target="_blank"
              rel="noopener"
              class="ml-2 text-ink underline-offset-4 hover:text-accent hover:underline"
            >linkedin.com/in/mjns</a>
          </li>
          <li>
            <span class="text-accent">$</span>
            quizzolingo
            <a
              href={site.quizzolingo}
              target="_blank"
              rel="noopener"
              class="ml-2 text-ink underline-offset-4 hover:text-accent hover:underline"
            >quizzolingo.com</a>
          </li>
        </ul>
      </header>

      <div class="rounded-2xl border border-line bg-surface p-7 sm:p-9">
        <p class="label mb-5">Available for</p>
        <ul class="space-y-4 text-sm text-ink/90 sm:text-base">
          <li class="flex gap-3">
            <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>
              <strong class="font-semibold text-ink">Fractional / part-time advisory</strong>
              <span class="text-muted"> — manufacturing-tech, industrial SaaS go-to-market.</span>
            </span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>
              <strong class="font-semibold text-ink">Expert-network calls</strong>
              <span class="text-muted"> — automotive launches, CATIA / 3DExperience, body-shop processes.</span>
            </span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>
              <strong class="font-semibold text-ink">Freelance automation</strong>
              <span class="text-muted"> — C# / VBA / Selenium projects, custom CAD tooling.</span>
            </span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>
              <strong class="font-semibold text-ink">Solutions Engineer / Industrial PM</strong>
              <span class="text-muted"> — remote, EU-based or worldwide via EOR.</span>
            </span>
          </li>
        </ul>

        <p class="mt-7 border-t border-line pt-5 font-mono text-xs leading-relaxed text-muted">
          Currently Slovakia-based. Relocating permanently to Thailand in Q4&nbsp;2026 — invoicing
          via Estonian OÜ, fully timezone-flexible.
        </p>
      </div>
    </div>
  </div>
</section>
